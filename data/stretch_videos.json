def render_video_section(title, videos):
    st.subheader(title)
    for video in videos:
        st.markdown(f"**{video['name']}** · {video['duration']}")
        st.markdown(f"""
        <iframe
            width="100%" height="315"
            src="{video['url']}?rel=0&modestbranding=1"
            allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
            allowfullscreen
            referrerpolicy="strict-origin-when-cross-origin"
            style="border:none; border-radius:8px;">
        </iframe>
        """, unsafe_allow_html=True)
        st.markdown("---")

render_video_section("🔥 Pre-Workout Warm-Up", VIDEO_DATA["pre_workout"])
render_video_section("❄️ Post-Workout Cool-Down", VIDEO_DATA["post_workout"])