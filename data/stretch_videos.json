        {"name": "Full Body Warm-Up",          "duration": "5 min", "url": "https://www.youtube.com/embed/1f8yoFFdkcY"},
        {"name": "Dynamic Stretching Routine", "duration": "4 min", "url": "https://www.youtube.com/embed/2pLT-olgUJs"},
